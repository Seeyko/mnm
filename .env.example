# =============================================================================
# MnM — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Lines starting with # are comments.
# =============================================================================

# --- Database ----------------------------------------------------------------
# External PostgreSQL connection string (required for docker-compose.dev.yml).
# When set, embedded-postgres is NOT used.
DATABASE_URL=postgres://mnm:mnm_dev@127.0.0.1:5432/mnm

# Port exposed by docker-compose.dev.yml (default: 5432)
# POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
# REDIS_URL=redis://127.0.0.1:6379

# --- Test environment --------------------------------------------------------
# DATABASE_URL=postgres://mnm_test:mnm_test@127.0.0.1:5433/mnm_test
# REDIS_URL=redis://127.0.0.1:6380

# --- Server ------------------------------------------------------------------
# PORT=3100
# HOST=127.0.0.1

# --- Deployment mode ---------------------------------------------------------
# local_trusted  — no auth, loopback only (default for dev)
# authenticated  — email/password or SSO
# MNM_DEPLOYMENT_MODE=local_trusted
# MNM_DEPLOYMENT_EXPOSURE=private

# --- Auth (authenticated mode only) ------------------------------------------
# BETTER_AUTH_SECRET=change-me-to-a-random-string
# MNM_PUBLIC_URL=http://localhost:3100
# MNM_AUTH_BASE_URL_MODE=auto
# MNM_AUTH_PUBLIC_BASE_URL=
# MNM_AUTH_DISABLE_SIGN_UP=false

# --- Database migrations -----------------------------------------------------
# MNM_MIGRATION_PROMPT=never

# --- Database backups --------------------------------------------------------
# MNM_DB_BACKUP_ENABLED=true
# MNM_DB_BACKUP_INTERVAL_MINUTES=60
# MNM_DB_BACKUP_RETENTION_DAYS=30
# MNM_DB_BACKUP_DIR=

# --- Secrets provider --------------------------------------------------------
# local_encrypted | env | vault
# MNM_SECRETS_PROVIDER=local_encrypted
# MNM_SECRETS_STRICT_MODE=false
# MNM_SECRETS_MASTER_KEY_FILE=

# --- Email (optional — falls back to console log in dev) --------------------
# RESEND_API_KEY=
# MNM_EMAIL_FROM=MnM <noreply@mnm.dev>
# MNM_PUBLIC_URL=http://localhost:5173

# --- Storage -----------------------------------------------------------------
# local_disk | s3
# MNM_STORAGE_PROVIDER=local_disk
# MNM_STORAGE_LOCAL_DIR=
# MNM_STORAGE_S3_BUCKET=mnm
# MNM_STORAGE_S3_REGION=us-east-1
# MNM_STORAGE_S3_ENDPOINT=
# MNM_STORAGE_S3_PREFIX=
# MNM_STORAGE_S3_FORCE_PATH_STYLE=false
